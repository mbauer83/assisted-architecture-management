{
  "mcpServers": {
    "arch-artifacts": {
      "command": "uv",
      "args": ["run", "arch-mcp-stdio"]
    },
    "arch-framework": {
      "command": "uv",
      "args": ["run", "arch-mcp-framework", "--transport", "stdio"],
      "env": {
        "ARCH_MCP_FRAMEWORK_DOC_ROOT": "engagements/ENG-ARCH-REPO/architecture-repository",
        "ARCH_MCP_FRAMEWORK_SCAN_DIRS": "docs"
      }
    }
  }
}
