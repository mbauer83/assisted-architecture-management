# C19C model/diagram/view exchange specs + example/interoperability-test snippets
# (license-encumbered reference material for the ArchiMate 4 compliance plan's
# WU-F1/F2/F3a/F3b exchange work — local reference only, never committed)
/spec/

# Guidance-cache files — license-encumbered spec prose, imported per repo via
# arch-import-guidance; the per-repo ignore lives in <repo>/.arch-repo/.gitignore, this is
# a belt-and-braces guard against a stray extract/import landing at the workspace root
*.guidance.yaml
*.guidance.meta.yaml

# Coverage analysis artifacts
.coverage
.coverage.*
coverage.xml
coverage.json
htmlcov/

# Hypothesis / pytest / ruff caches
.hypothesis/
.pytest_cache/
.ruff_cache/

# Stray local screenshots (Playwright MCP cwd captures, etc.)
/overview.png

# Playwright/test run output
test-results/

# Local working checkouts of git-backed workspace repos (cloned by arch-init from
# the remotes in arch-workspace.yaml; never committed into the superproject — they
# were previously accidental gitlinks with no .gitmodules entry).
/enterprise-repository/
/u2p-enterprise-repository/
/engagements/TECHNOLOGY_ARCHITECTURE/architecture-repository/
# Agent auto-memory working store (not project content)
/memory/
