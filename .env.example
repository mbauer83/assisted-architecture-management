# ─────────────────────────────────────────────────────────────────────────────
# Architectonic docker-compose configuration. Copy to `.env` and edit.
#   cp .env.example .env
# Secrets live here; declarative model/backend config lives in the mounted
# arch-workspace.server.yaml and config/settings.server.yaml files.
# ─────────────────────────────────────────────────────────────────────────────

# ── Profiles ─────────────────────────────────────────────────────────────────
# Comma-separated. Leave empty for the default stack (GUI + MCP, no assurance).
#   proxy       → Caddy TLS reverse proxy in front of the app
#   pocketbase  → PocketBase service as the assurance store backend
# COMPOSE_PROFILES=proxy

# ── Image / networking ───────────────────────────────────────────────────────
ARCH_IMAGE_TAG=local
ARCH_APP_BIND=0.0.0.0          # bind the app port to this host interface
ARCH_APP_PORT=8000             # host port → container :8000

# ── Declarative config file locations (host paths, mounted into the container) ─
ARCH_WORKSPACE_FILE=./arch-workspace.server.yaml
ARCH_SETTINGS_FILE=./config/settings.server.yaml

# ── Git sync credentials (non-interactive) ───────────────────────────────────
# Provide whichever your remotes need. Repos are declared in the workspace file.
# HTTPS (use a personal access token as the password):
ARCH_GIT_HTTPS_USERNAME=
ARCH_GIT_HTTPS_PASSWORD=
# SSH (passphrase for the mounted key; mount the key via a volume + GIT_SSH_COMMAND):
ARCH_GIT_SSH_PASSWORD=
# Initialise empty configured git repos on first boot (set to any value to enable):
# ARCH_INIT_ENGAGEMENT_IF_EMPTY=1
# ARCH_INIT_ENTERPRISE_IF_EMPTY=1

# ── Backend modes (optional) ─────────────────────────────────────────────────
# ARCH_READ_ONLY=1             # block engagement writes (review/read deployments)
# ARCH_ADMIN_MODE=1            # enable enterprise writes via /admin/api/*

# ── Assurance (OPT-IN). Default deployment runs WITHOUT assurance. ────────────
ARCH_ENABLE_ASSURANCE=false
# Required when assurance is enabled with the sqlcipher store (headless vault key):
ARCH_ASSURANCE_MASTER_PASSWORD=
# Storage matrix (only used when ARCH_ENABLE_ASSURANCE=true):
ARCH_ASSURANCE_STORE_BACKEND=sqlcipher          # sqlcipher | private-git | pocketbase
ARCH_ASSURANCE_SIGNALS_BACKEND=sqlcipher-colocated  # sqlcipher-colocated | sqlite | encrypted
ARCH_ASSURANCE_ARCHIVE_BACKEND=standard         # standard | worm | s3-worm | azure-blob-worm
# TLP exposure ceiling — highest classification served over REST/MCP.
# TLP:WHITE | TLP:GREEN | TLP:AMBER | TLP:RED  (overrides the baked default)
ARCH_MAX_CLASSIFICATION=TLP:AMBER

# ── PocketBase store (profile: pocketbase) ───────────────────────────────────
# ARCH_POCKETBASE_URL=http://pocketbase:8090
# ARCH_POCKETBASE_ADMIN_EMAIL=admin@example.com
# ARCH_POCKETBASE_ADMIN_PASSWORD=

# ── S3 WORM archive (ARCH_ASSURANCE_ARCHIVE_BACKEND=s3-worm) ──────────────────
# ARCH_S3_BUCKET=
# ARCH_S3_OBJECT_LOCK_MODE=GOVERNANCE            # GOVERNANCE | COMPLIANCE
# ARCH_S3_REGION=
# ARCH_S3_RETENTION_DAYS=365
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Azure WORM archive (ARCH_ASSURANCE_ARCHIVE_BACKEND=azure-blob-worm) ───────
# ARCH_AZURE_STORAGE_ACCOUNT=
# ARCH_AZURE_CONTAINER=arch-assurance
# ARCH_AZURE_STORAGE_KEY=

# ── Reverse proxy (profile: proxy) ───────────────────────────────────────────
ARCH_SITE_ADDRESS=https://arch.internal        # the VPN hostname clients use
ARCH_HTTPS_PORT=443
ARCH_HTTP_PORT=80
