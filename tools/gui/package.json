{
  "name": "arch-gui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/.eslintcache --max-warnings=0 --ext .js,.ts,.vue",
    "lint:fix": "npm run lint -- --fix",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "codemirror": "^6.0.2",
    "d3-hierarchy": "^3.1.2",
    "dompurify": "^3.4.0",
    "effect": "^3.12.0",
    "marked": "^18.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.15.17",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.25.1",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.2.6",
    "vue-eslint-parser": "^10.1.3",
    "vue-tsc": "^2.2.0"
  }
}
